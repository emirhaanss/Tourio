@model CreateTourBookingInformationDto
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tur Rezervasyonu - Tourio</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f4f7f6;
            font-family: 'Poppins', sans-serif;
        }

        .reservation-card {
            border: none;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            overflow: hidden;
        }

        .reservation-header {
            background: linear-gradient(135deg, #6e8efb, #a777e3);
            color: white;
            padding: 30px;
            text-align: center;
        }

        .form-control, .form-select {
            border-radius: 8px;
            padding: 12px;
            border: 1px solid #ddd;
        }

        .btn-reserve {
            background: #6e8efb;
            color: white;
            padding: 12px;
            border-radius: 8px;
            font-weight: 600;
            transition: all 0.3s ease;
            width: 100%;
            border: none;
        }

            .btn-reserve:hover {
                background: #5a7be2;
                transform: translateY(-2px);
            }
    </style>
</head>
<body>

    <div class="container mt-5 mb-5">
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="card reservation-card">
                    <div class="reservation-header">
                        <h2>Maceranı Planla</h2>
                        <p class="mb-0">Hayalindeki tur için bilgileri doldurman yeterli.</p>
                    </div>
                    <div class="card-body p-4 p-md-5">

                        <form asp-controller="TourReservation" asp-action="CreateTourReservation" method="post">

                            <div class="row">
                                <div class="col-md-12 mb-3">
                                    <label class="form-label fw-bold">Seçili Tur</label>

                                    <select asp-for="TourId" class="form-select" required>
                                        <option value="">Lütfen bir tur seçin...</option>
                                        @if (ViewBag.Tours != null)
                                        {
                                            foreach (var item in ViewBag.Tours)
                                            {
                                                <option value="@item.TourID">@item.Title</option>
                                            }
                                        }
                                    </select>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Ad Soyad</label>
                                    <input type="text" asp-for="NameSurname" class="form-control" placeholder="Adınız ve Soyadınız" required>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">E-posta Adresi</label>
                                    <input type="email" asp-for="Email" class="form-control" placeholder="mail@ornek.com" required>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Telefon Numarası</label>
                                    <input type="tel" asp-for="PhoneNumber" class="form-control" placeholder="05xx xxx xx xx" required>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Kişi Sayısı</label>
                                    <input type="number" asp-for="PersonCount" class="form-control" min="1" max="20" required>
                                </div>

                                <div class="col-md-12 mb-4">
                                    <label class="form-label fw-bold">Tercih Edilen Tarih</label>
                                    <input type="date" asp-for="ReservationDate" class="form-control" required>
                                </div>
                                <div class="col-md-12">
                                    <button type="submit" class="btn btn-reserve shadow-sm">Rezervasyonu Tamamla</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
                <p class="text-center mt-4 text-muted small">&copy; 2026 Tourio - Tüm hakları saklıdır.</p>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
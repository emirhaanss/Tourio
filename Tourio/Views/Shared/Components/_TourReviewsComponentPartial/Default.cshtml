@model List<ResultReviewByTourIdDto>

<div class="tab-pane fade" id="pills-reviews" role="tabpanel"
     aria-labelledby="pills-reviews-tab" tabindex="0">
    <div class="row">
        <div class="col-lg-8">
            <div class="review-content-tour">

                <div class="custom-review mb-50">
                    <h4 class="title-review mb-4 fw-bold">Müşteri Değerlendirmeleri</h4>
                    <div class="row align-items-center card-list p-4 shadow-sm rounded-4 border bg-white">
                        <div class="col-md-4 text-center border-end">
                            <div class="overall-rating">
                                <h2 class="display-4 fw-bolder text-primary mb-0">4.8</h2>
                                <div class="stars my-2 text-warning">
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-half"></i>
                                </div>
                                <span class="text-muted">Toplam Değerlendirme</span>
                            </div>
                        </div>
                        <div class="col-md-8 ps-md-4">
                            @foreach (var category in new[] { "Konfor", "Rehberlik", "Fiyat/Performans" })
                            {
                                <div class="review-list-item mb-3">
                                    <div class="d-flex justify-content-between mb-1">
                                        <span class="fw-bold" style="font-size: 14px;">@category</span>
                                        <span class="text-muted small">4.8 / 5</span>
                                    </div>
                                    <div class="progress" style="height: 8px;">
                                        <div class="progress-bar bg-success" style="width: 90%"></div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="client-review-section">
                    <div class="d-flex justify-content-between align-items-center mb-4 inner-header">
                        <h4 class="title-review fw-bold m-0">Kullanıcı Yorumları</h4>
                        <div class="badge bg-light text-dark p-2 px-3 border rounded-pill">
                            <span class="fw-bold">@Model.Count Yorum</span>
                        </div>
                    </div>

                    <div class="review-list-container">
                        @foreach (var item in Model)
                        {
                            <div class="client-review-item p-4 mb-4 bg-white border rounded-4 shadow-sm">
                                <div class="d-flex gap-3">
                                    <div class="avatar-wrapper">
                                        <img src="~/assets/images/avata/avt-review.jpg"
                                             class="rounded-circle shadow-sm"
                                             style="width: 60px; height: 60px; object-fit: cover;" alt="avatar">
                                    </div>
                                    <div class="content w-100">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <div>
                                                <h6 class="name fw-bold m-0">@item.NameSurname</h6>
                                                <small class="text-muted">@item.ReviewDate.ToString("dd MMM yyyy")</small>
                                            </div>
                                            <div class="badge bg-primary-soft text-primary p-2">
                                                <i class="bi bi-star-fill me-1"></i>@item.Score
                                            </div>
                                        </div>
                                        <p class="text-muted" style="line-height: 1.6; font-size: 14px;">
                                            @item.Detail
                                        </p>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            @await Component.InvokeAsync("_TourRightSidebarComponentPartial")
        </div>
    </div>
</div>

<style>
    /* Yorumlara özel ek stiller */
    .bg-primary-soft {
        background-color: #f0fdfa;
        color: #26b6a6;
        border-radius: 8px;
    }

    .client-review-item {
        transition: transform 0.3s ease;
    }

        .client-review-item:hover {
            transform: translateY(-5px);
        }

    .progress-bar {
        background-color: #26b6a6 !important;
    }
</style>
<div class="tab-pane fade" id="pills-location-share" role="tabpanel"
     aria-labelledby="pills-location-share-tab" tabindex="0">
    <div class="row">
        <div class="col-lg-8">
            <div class="localtion-content-tour">

                <div class="map-wrapper mb-40">
                    <div id="map2" style="height: 450px; border-radius: 24px; border: 1px solid #f0f0f0; box-shadow: 0 12px 35px rgba(0,0,0,0.06);"></div>

                    <div class="address-premium-card d-flex align-items-center gap-3 mt-4">
                        <div class="icon-box-cyan">
                            <i class="bi bi-geo-alt-fill"></i>
                        </div>
                        <div>
                            <span class="text-uppercase fw-bold text-muted" style="font-size: 11px; letter-spacing: 1px;">Merkezi Buluşma Noktası</span>
                            <p class="m-0 fw-bold" style="color: #1a1a1a; font-size: 16px;">1421 San Pedro St, Los Angeles, CA</p>
                        </div>
                    </div>
                </div>

                <div class="info-section mb-40">
                    <h3 class="fw-extrabold mb-3" style="color: #1a1a1a;">Tur Lokasyonu Hakkında</h3>
                    <p class="text-muted mb-4" style="line-height: 1.8; font-size: 15px;">
                        Turlarımızın başlangıç noktası ulaşımı kolay ve merkezi bir konumdadır.
                        Rehberimiz sizi belirtilen adreste tur saatinden 15 dakika önce karşılayacaktır.
                    </p>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <ul class="list-unstyled">
                                <li class="mb-3 d-flex align-items-center gap-2">
                                    <i class="bi bi-check2-circle text-success fw-bold" style="font-size: 20px;"></i>
                                    <span class="fw-semibold">Şehir Surlarını Ziyaret</span>
                                </li>
                                <li class="mb-3 d-flex align-items-center gap-2">
                                    <i class="bi bi-check2-circle text-success fw-bold" style="font-size: 20px;"></i>
                                    <span class="fw-semibold">Ormanda Doğa Yürüyüşü</span>
                                </li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <ul class="list-unstyled">
                                <li class="mb-3 d-flex align-items-center gap-2">
                                    <i class="bi bi-check2-circle text-success fw-bold" style="font-size: 20px;"></i>
                                    <span class="fw-semibold">"The Lark" Seyir Noktası</span>
                                </li>
                                <li class="mb-3 d-flex align-items-center gap-2">
                                    <i class="bi bi-check2-circle text-success fw-bold" style="font-size: 20px;"></i>
                                    <span class="fw-semibold">Teknede Gün Batımı Keyfi</span>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="departure-points-section">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div style="width: 4px; height: 25px; background: #26b6a6; border-radius: 10px;"></div>
                        <h4 class="m-0 fw-bold" style="color: #1a1a1a;">Servis ve Kalkış Noktaları</h4>
                    </div>

                    <div class="timeline-container-modern">
                        <div class="timeline-item-modern">
                            <div class="timeline-marker">
                                <div class="dot-main"></div>
                                <div class="line-connector"></div>
                            </div>
                            <div class="timeline-text">
                                <h6>Mecidiyeköy Metrobüs</h6>
                                <p>MÜSİAD binası önü servis alanı.</p>
                            </div>
                        </div>

                        <div class="timeline-item-modern">
                            <div class="timeline-marker">
                                <div class="dot-main"></div>
                                <div class="line-connector"></div>
                            </div>
                            <div class="timeline-text">
                                <h6>Kadıköy Evlendirme Dairesi</h6>
                                <p>Otopark girişindeki ana durak noktası.</p>
                            </div>
                        </div>

                        <div class="timeline-item-modern">
                            <div class="timeline-marker">
                                <div class="dot-main"></div>
                            </div>
                            <div class="timeline-text">
                                <h6>Kartal Köprüsü</h6>
                                <p>E-5 yanyol Ankara istikameti durağı.</p>
                            </div>
                        </div>
                    </div>

                    <div class="alert-modern mt-4">
                        <i class="bi bi-exclamation-circle-fill me-2"></i>
                        <span>Lütfen servis saatinden 10 dakika önce belirtilen noktada hazır bulununuz.</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            @await Component.InvokeAsync("_TourRightSidebarComponentPartial")
        </div>
    </div>
</div>

<style>
    /* Genel Yardımcı Sınıflar */
    .fw-extrabold {
        font-weight: 800;
    }

    .mb-40 {
        margin-bottom: 40px;
    }

    /* Adres Kartı */
    .address-premium-card {
        background: #fff;
        padding: 22px;
        border-radius: 20px;
        border: 1px solid #f1f4f2;
        box-shadow: 0 8px 25px rgba(0,0,0,0.03);
    }

    .icon-box-cyan {
        width: 50px;
        height: 50px;
        background: #f0fdfa;
        color: #26b6a6;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
    }

    /* Timeline Yapısı */
    .timeline-container-modern {
        background: #ffffff;
        padding: 30px;
        border-radius: 24px;
        border: 1px solid #f1f4f2;
    }

    .timeline-item-modern {
        display: flex;
        gap: 20px;
    }

    .timeline-marker {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .dot-main {
        width: 16px;
        height: 16px;
        background: #26b6a6;
        border: 4px solid #c3f6e9;
        border-radius: 50%;
    }

    .line-connector {
        width: 2px;
        flex-grow: 1;
        background: #f1f4f2;
        margin: 5px 0;
    }

    .timeline-text h6 {
        font-weight: 700;
        margin: 0;
        font-size: 16px;
        color: #1a1a1a;
    }

    .timeline-text p {
        font-size: 13px;
        color: #777;
        margin-top: 4px;
        margin-bottom: 25px;
    }

    .timeline-item-modern:last-child .timeline-text p {
        margin-bottom: 0;
    }

    /* Uyarı Kutusu */
    .alert-modern {
        background: #fff9e6;
        color: #856404;
        padding: 15px 20px;
        border-radius: 12px;
        border-left: 5px solid #ffc107;
        font-size: 14px;
        font-weight: 600;
    }
</style>
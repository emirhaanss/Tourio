@model List<ResultTourDto>
<style>
    /* Genel Sidebar Alanı */
    .side-bar-right {
        /* Kartı daha aşağı indirmek için margin'i artırdık */
        margin-top: 40px !important;
        padding-top: 0 !important;
    }

    /* Premium Kart Yapısı */
    .sidebar-widget {
        background: #ffffff;
        border-radius: 24px; /* Daha yumuşak köşeler */
        padding: 30px; /* Daha ferah iç boşluk */
        /* Daha derin ve yumuşak gölge */
        box-shadow: 0 15px 50px rgba(0,0,0,0.06);
        border: 1px solid #f1f4f2;
        margin-bottom: 35px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .sidebar-widget:hover {
            transform: translateY(-5px); /* Hafif yukarı kalkma efekti */
            box-shadow: 0 20px 60px rgba(0,0,0,0.1);
        }

    /* Başlıklar */
    .block-heading {
        font-size: 20px;
        font-weight: 800;
        color: #1a1a1a;
        margin-bottom: 25px;
        padding-bottom: 12px;
        border-bottom: 3px solid #26b6a6; /* Daha kalın alt çizgi */
        display: inline-block;
        letter-spacing: -0.5px;
    }

    /* Input ve Select Modernizasyonu */
    .input-wrap input[type="date"] {
        width: 100%;
        padding: 14px;
        border-radius: 14px;
        border: 1px solid #e9ecef;
        background: #f8f9fa;
        font-weight: 600;
        color: #495057;
        transition: 0.3s;
    }

        .input-wrap input[type="date"]:focus {
            border-color: #26b6a6;
            background: #fff;
            box-shadow: 0 0 0 4px rgba(38, 182, 166, 0.1);
            outline: none;
        }

    /* Saat Seçimi (Radio Button Modernizasyonu) */
    .radio {
        display: flex;
        gap: 12px;
    }

        .radio input {
            display: none;
        }

        .radio label {
            flex: 1;
            padding: 10px 18px;
            text-align: center;
            background: #f8f9fa;
            border: 1px solid #e9ecef;
            border-radius: 10px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 700;
            transition: 0.3s;
            color: #555;
        }

        .radio input:checked + label {
            background: #26b6a6;
            color: #fff;
            border-color: #26b6a6;
            box-shadow: 0 5px 15px rgba(38, 182, 166, 0.2);
        }

    /* Bilet Satırları */
    .ticket-row-modern {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 18px;
        padding-bottom: 12px;
        border-bottom: 1px dashed #eee;
    }

    .ticket-info p {
        margin: 0;
        font-size: 15px;
        font-weight: 600;
        color: #333;
    }

    .ticket-info span {
        font-size: 13px;
        color: #26b6a6;
        font-weight: 700;
    }

    /* Extra Seçenekler */
    .checkbox-modern {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
        font-size: 15px;
        font-weight: 600;
        color: #555;
    }

        .checkbox-modern input {
            accent-color: #26b6a6;
            width: 20px;
            height: 20px;
        }

    /* Toplam Tutar Alanı */
    .total-box {
        background: #f0fdfa; /* Ferah bir turkuaz tonu */
        padding: 18px;
        border-radius: 14px;
        margin: 25px 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border: 1px solid #c3f6e9;
    }

        .total-box .total-label {
            font-weight: 700;
            color: #1a1a1a;
            font-size: 16px;
        }

        .total-box .total-price {
            font-size: 26px;
            font-weight: 900;
            color: #26b6a6;
            letter-spacing: -1px;
        }

    /* Buton */
    .btn-book-now {
        width: 100%;
        background: linear-gradient(135deg, #26b6a6 0%, #1f9689 100%); /* Hafif gradyan */
        color: white;
        border: none;
        padding: 18px;
        border-radius: 14px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        transition: 0.3s;
        box-shadow: 0 8px 20px rgba(38, 182, 166, 0.3);
        cursor: pointer;
    }

        .btn-book-now:hover {
            box-shadow: 0 12px 30px rgba(38, 182, 166, 0.4);
            transform: translateY(-3px);
        }

    /* Güven Listesi */
    .category-confidence li {
        margin-bottom: 18px;
        font-size: 14px;
        color: #555;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 15px;
        background: #f8f9fa;
        padding: 12px;
        border-radius: 12px;
        border: 1px solid #e9ecef;
    }

    .category-confidence i {
        color: #26b6a6;
        font-size: 20px;
    }

    /* Son Turlar Listesi */
    .list-recent {
        margin-bottom: 20px;
        border-bottom: 1px solid #eee;
        padding-bottom: 15px;
    }

        .list-recent:last-child {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }

    .recent-image img {
        width: 80px;
        height: 80px;
        border-radius: 14px;
        object-fit: cover;
    }

    .recent-info .title {
        font-size: 15px;
        font-weight: 700;
        margin: 5px 0;
    }

        .recent-info .title a {
            color: #1a1a1a;
            transition: 0.2s;
        }

            .recent-info .title a:hover {
                color: #26b6a6;
            }

    .recent-info .start i {
        color: #ffa800;
        font-size: 13px;
    }

        .recent-info .start i.icon-Star.empty {
            color: #e9ecef;
        }
    /* Boş yıldız stili */
</style>

<div class="side-bar-right">
    <div class="sidebar-widget">
        <h6 class="block-heading">Turu Rezerve Et</h6>
        <form id="form-book-tour">
            <div class="input-wrap mb-25">
                <span class="d-block mb-2 font-weight-bold" style="font-size: 12px; color:#adb5bd; text-transform:uppercase; letter-spacing:1px;">Tarih Seçin</span>
                <input type="date">
            </div>

            <div class="mb-25">
                <span class="d-block mb-2 font-weight-bold" style="font-size: 12px; color:#adb5bd; text-transform:uppercase; letter-spacing:1px;">Saat</span>
                <div class="radio">
                    <input id="first" type="radio" name="time" value="14.00" checked>
                    <label for="first">14.00</label>
                    <input id="second" type="radio" name="time" value="16.00">
                    <label for="second">16.00</label>
                </div>
            </div>

            <div class="ticket-selection mb-25">
                <span class="d-block mb-2 font-weight-bold" style="font-size: 12px; color:#adb5bd; text-transform:uppercase; letter-spacing:1px;">Biletler</span>

                <div class="ticket-row-modern">
                    <div class="ticket-info">
                        <p>Yetişkin (18+)</p>
                        <span>$189.00</span>
                    </div>
                    <select class="form-select form-select-sm w-auto border-light bg-light rounded-pill px-3">
                        <option value="1">1</option>
                        <option value="2">2</option>
                        <option value="3">3</option>
                    </select>
                </div>

                <div class="ticket-row-modern">
                    <div class="ticket-info">
                        <p>Çocuk (0-12)</p>
                        <span>$129.00</span>
                    </div>
                    <select class="form-select form-select-sm w-auto border-light bg-light rounded-pill px-3">
                        <option value="0">0</option>
                        <option value="1">1</option>
                        <option value="2">2</option>
                    </select>
                </div>
            </div>

            <div class="total-box">
                <span class="total-label">Toplam Tutar:</span>
                <span class="total-price">$189.00</span>
            </div>

            <button type="submit" class="btn-book-now">Güvenli Ödemeye Geç</button>
        </form>
    </div>

    <div class="sidebar-widget">
        <h6 class="block-heading">Güvenli Rezervasyon</h6>
        <ul class="category-confidence list-unstyled m-0">
            <li><i class="icon-customer-service-1"></i> 7/24 Müşteri Desteği</li>
            <li><i class="icon-Vector-6"></i> Özenle Seçilmiş Aktiviteler</li>
            <li><i class="icon-insurance-1"></i> Ücretsiz Seyahat Sigortası</li>
            <li><i class="icon-price-tag-1-1"></i> En İyi Fiyat Garantisi</li>
        </ul>
    </div>

    <div class="sidebar-widget">
        <h6 class="block-heading">Son Turlar</h6>
        @foreach (var item in Model)
        {
            <div class="recent-post-list">
                <div class="list-recent d-flex align-items-center gap-3">
                    <a href="#" class="recent-image">
                        <img src="@item.CoverImageUrl" alt="Tour">
                    </a>
                    <div class="recent-info">
                        <div class="start">
                            <i class="icon-Star"></i><i class="icon-Star"></i><i class="icon-Star"></i><i class="icon-Star"></i><i class="icon-Star empty"></i>
                        </div>
                        <h4 class="title"><a href="#">@item.Title</a></h4>
                        <p class="m-0" style="font-size: 13px;">@item.Price $ <span class="text-main font-weight-bold">Başlayan fiyatlarla</span></p>
                    </div>
                </div>

            </div>
        }

    </div>
</div>